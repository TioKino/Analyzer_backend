# ============================================================
# DJ ANALYZER - BACKEND ENVIRONMENT VARIABLES
# ============================================================
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores con tus tokens reales
#   3. NUNCA commitees .env a Git
#
# PRODUCCIÓN (Render):
#   Configura estas variables en el dashboard del hosting.
#   Render auto-deploya desde `main` (ver railway.toml: ELIMINADO
#   2026-05-01 — el proyecto ya no usa Railway).

# ==================== API TOKENS ====================

# AudD API - Para identificación de canciones (manual y automática
# cuando ID3 falta, ver AUDD_AUTO_* abajo)
# Obtén tu token en: https://dashboard.audd.io/
AUDD_API_TOKEN=tu_token_audd_aqui

# Discogs API - Para metadata de géneros y sellos
# Obtén tu token en: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=tu_token_discogs_aqui

# MusicBrainz User Agent (no requiere token)
MUSICBRAINZ_USER_AGENT=DJAnalyzerPro/2.3.0 (tu@email.com)

# ==================== AUDD AUTO-TRIGGER ====================
# Disparo automático de AudD durante /analyze cuando los metadatos ID3
# + parsing de filename no devuelven artist/title válidos. Implementado
# en audd_helper.py. Cap diario para limitar coste.

AUDD_AUTO_ENABLED=true
AUDD_DAILY_CAP=50
AUDD_COOLDOWN_DAYS=7
AUDD_MIN_DURATION=30
AUDD_MAX_DURATION=720

# ==================== SERVIDOR ====================

# Puerto (Render configura $PORT automáticamente)
PORT=8000

# Modo debug (true = más logging)
DEBUG=true

# URL base del servidor
# - Desarrollo: http://192.168.x.x:8000
# - Producción Render: https://dj-analyzer-api.onrender.com
BASE_URL=http://192.168.1.134:8000

# ==================== BASE DE DATOS ====================

DATABASE_PATH=analysis.db
ARTWORK_CACHE_DIR=artwork_cache

# ==================== LÍMITES ====================

MAX_FILE_SIZE_MB=100
ANALYSIS_TIMEOUT_SECONDS=180
# Timeout en segundos para generar el snippet MP3 vía ffmpeg.
# Default 15s. Render Standard con CPU compartida puede necesitar 30-45s
# para tracks de 200+ MB.
PREVIEW_TIMEOUT_SECONDS=15

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
# Numero de proxies de CONFIANZA delante de la app, para resolver la IP real
# del cliente desde X-Forwarded-For sin que se pueda falsear (el rate-limit se
# agrupa por esa IP). Render = 1 (su load balancer). Si pones algo mas delante
# (p.ej. Cloudflare -> Render) = 2. Default 1.
TRUSTED_PROXY_HOPS=1

# ==================== CORS ====================

# Orígenes permitidos (separados por coma, o * para todos)
CORS_ORIGINS=*
